# ── Provider selection ────────────────────────────────────────────────────────
# Allowed values: openai | anthropic | google | xai | mistral | groq | zai
# Default: openai
LLM_PROVIDER=openai

# ── API keys — set only the key for your chosen provider ─────────────────────
OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# GOOGLE_GENERATIVE_AI_API_KEY=your_key_here
# XAI_API_KEY=your_key_here
# MISTRAL_API_KEY=your_key_here
# GROQ_API_KEY=your_key_here
# ZAI_API_KEY=your_key_here

# ── Model name — must match the chosen provider's model IDs ──────────────────
# openai:    gpt-4o, gpt-4o-mini, gpt-4-turbo, ...
# anthropic: claude-sonnet-4-5, claude-opus-4, claude-haiku-3-5, ...
# google:    gemini-2.0-flash, gemini-1.5-pro, ...
# xai:       grok-beta, grok-2, ...
# mistral:   mistral-large-latest, mistral-small-latest, ...
# groq:      llama-3.3-70b-versatile, llama-3.1-8b-instant, ...
# zai:       glm-5, glm-4.7, glm-4.6, glm-5-turbo, ...
LLM_MODEL=gpt-4o

# ── Tunable parameters (all have defaults — only set if you want to override) ─
SCORE_THRESHOLD=7
TOP_N_SEGMENTS=10
CHUNK_LENGTH_SEC=120
CHUNK_OVERLAP_SEC=20
MICRO_BLOCK_SEC=15
LLM_MAX_RETRIES=3
DOWNLOAD_DIR=downloads/
OUTPUT_DIR=outputs/
