{
  "name": "video-clipper",
  "version": "1.0.0",
  "description": "CLI that analyzes YouTube transcripts with an LLM to find interesting moments and cut clips",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --project tsconfig.test.json",
    "lint": "tsc --project tsconfig.test.json",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai": "^1.3.22",
    "@ai-sdk/xai": "^3.0.67",
    "ai": "^4.3.16",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "fluent-ffmpeg": "^2.1.3",
    "p-limit": "^7.3.0",
    "youtube-transcript": "^1.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
