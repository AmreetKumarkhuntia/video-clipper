{
  "name": "@thunderkiller/video-clipper",
  "version": "1.5.1",
  "description": "CLI that analyzes YouTube transcripts with an LLM to find interesting moments and cut clips",
  "license": "ISC",
  "author": "",
  "packageManager": "pnpm@10.12.4",
  "type": "module",
  "main": "dist/index.js",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmreetKumarkhuntia/video-clipper.git"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --project tsconfig.test.json",
    "lint": "tsc --project tsconfig.test.json",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky",
    "release:dry": "npx semantic-release --dry-run"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.70",
    "@ai-sdk/google": "^2.0.62",
    "@ai-sdk/groq": "^2.0.36",
    "@ai-sdk/mistral": "^2.0.29",
    "@ai-sdk/openai": "^2.0.99",
    "@ai-sdk/openai-compatible": "^1.0.34",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/xai": "^2.0.62",
    "@google/generative-ai": "^0.21.0",
    "ai": "^5.0.154",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "fluent-ffmpeg": "^2.1.3",
    "p-limit": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
