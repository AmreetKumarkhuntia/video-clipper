{
  "name": "@thunderkiller/video-clipper",
  "version": "1.10.0",
  "description": "CLI that analyzes YouTube transcripts with an LLM to find interesting moments and cut clips",
  "license": "ISC",
  "author": "Amreet Kumar Khuntia",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "keywords": [
    "youtube",
    "video-clipper",
    "llm",
    "transcript",
    "ffmpeg",
    "clips",
    "ai",
    "segmentation",
    "yt-dlp",
    "vercel-ai-sdk",
    "video",
    "highlights"
  ],
  "type": "module",
  "main": "dist/lib/index.js",
  "module": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "bin": {
    "video-clipper": "dist/app/cli/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/lib/index.js"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/app/cli/index.d.ts",
        "default": "./dist/app/cli/index.js"
      }
    }
  },
  "files": [
    "dist",
    "scripts",
    "requirements.txt"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmreetKumarkhuntia/video-clipper.git"
  },
  "scripts": {
    "start": "tsx src/app/cli/index.ts",
    "build": "tsc && tsc-alias",
    "web:dev": "vite --host 0.0.0.0 --port 5002",
    "web:build": "vite build",
    "web:preview": "vite preview --host 0.0.0.0",
    "web:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.web.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "type-check": "tsc --project tsconfig.test.json",
    "lint": "tsc --project tsconfig.test.json",
    "format": "prettier --write \"src/**/*.{ts,svelte}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte}\" \"tests/**/*.ts\"",
    "prepare": "husky",
    "release:dry": "npx semantic-release --dry-run",
    "db:browse": "sqlite_web \"${LIBRARY_DB_PATH:-$HOME/.config/video-clipper/library.sqlite}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.{ts,svelte}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.70",
    "@ai-sdk/google": "^2.0.62",
    "@ai-sdk/groq": "^2.0.36",
    "@ai-sdk/mistral": "^2.0.29",
    "@ai-sdk/openai": "^2.0.99",
    "@ai-sdk/openai-compatible": "^1.0.34",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/xai": "^2.0.62",
    "@google/generative-ai": "^0.21.0",
    "@googleapis/youtube": "^31.0.0",
    "ai": "^5.0.154",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "eventsource-parser": "^3.0.0",
    "execa": "^9.5.2",
    "fluent-ffmpeg": "^2.1.3",
    "mongodb": "^7.1.0",
    "nanoid": "^5.1.11",
    "p-limit": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@sveltejs/adapter-node": "^5.2.13",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.19.19",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "3.3.3",
    "semantic-release": "^25.0.3",
    "svelte": "^5.55.5",
    "svelte-check": "4.1.1",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^5.4.21",
    "vitest": "^3.0.8"
  }
}
