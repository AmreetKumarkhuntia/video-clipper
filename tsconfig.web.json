{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["src/app/web/lib/*"],
      "@lib/*": ["src/lib/*"],
      "@app/cli/*": ["src/app/cli/*"],
      "@app/web/*": ["src/app/web/*"]
    }
  },
  "include": ["src/app/web/**/*.svelte", "src/app/web/**/*.ts", "src/lib/**/*.ts", "vite.config.ts"]
}
