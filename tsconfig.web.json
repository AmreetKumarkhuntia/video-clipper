{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": false,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@app/cli/*": ["src/app/cli/*"],
      "@app/web/*": ["src/app/web/*"],
      "@web/lib/*": ["src/app/web/lib/*"],
      "@web/components/*": ["src/app/web/components/*"]
    }
  },
  "include": [
    "src/**/*.d.ts",
    "src/app/web/**/*.svelte",
    "src/app/web/**/*.ts",
    "src/lib/**/*.ts",
    "vite.config.ts"
  ]
}
