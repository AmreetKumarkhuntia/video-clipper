{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@app/cli/*": ["src/app/cli/*"],
      "@app/web/*": ["src/app/web/*"],
      "@web/lib/*": ["src/app/web/lib/*"],
      "@web/components/*": ["src/app/web/components/*"],
      "@web/widgets/*": ["src/app/web/widgets/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
